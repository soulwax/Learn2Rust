{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo: check workspace",
      "type": "shell",
      "command": "cargo",
      "args": ["check"],
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "cargo: test workspace",
      "type": "shell",
      "command": "cargo",
      "args": ["test"],
      "group": "test",
      "problemMatcher": "$rustc"
    },
    {
      "label": "cargo: fmt check",
      "type": "shell",
      "command": "cargo",
      "args": ["fmt", "--check"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cargo: clippy workspace",
      "type": "shell",
      "command": "cargo",
      "args": ["clippy", "--workspace", "--all-targets", "--all-features"],
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "run: ch00 setup lab",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "-p", "ch00_setup"],
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "run: ch01 basics lab",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "-p", "ch01_basics"],
      "group": "build",
      "problemMatcher": "$rustc"
    },
    {
      "label": "run: ch02 ownership lab",
      "type": "shell",
      "command": "cargo",
      "args": ["run", "-p", "ch02_ownership"],
      "group": "build",
      "problemMatcher": "$rustc"
    }
  ]
}
